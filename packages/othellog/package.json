{
  "name": "@thenightex/othellog",
  "version": "0.2.1",
  "packageManager": "pnpm@10.33.2",
  "author": {
    "name": "Sascha Hanke",
    "email": "s.hanke1316@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thenightex/admiring-darwin.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/othellog.umd.cjs",
  "module": "./dist/othellog.js",
  "types": "./dist/othellog.d.ts",
  "exports": {
    ".": {
      "import": "./dist/othellog.js",
      "require": "./dist/othellog.umd.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepublish": "pnpm run build",
    "lint:oxlint": "oxlint . --fix --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix --cache",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "sizecheck": "npx vite-bundle-visualizer",
    "taze": "npx taze"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@microsoft/api-extractor": "^7.58.7",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-flat-config-utils": "^3.1.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-oxlint": "^1.62.0",
    "eslint-plugin-pnpm": "^1.6.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "taze": "^19.11.0",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^8.0.9",
    "vite-bundle-visualizer": "^1.2.1"
  },
  "engines": {
    "node": ">=24.14",
    "pnpm": ">=10"
  }
}
