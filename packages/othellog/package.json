{
  "name": "@thenightex/othellog",
  "version": "0.2.1",
  "packageManager": "pnpm@10.33.2",
  "author": {
    "name": "Sascha Hanke",
    "email": "s.hanke1316@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thenightex/admiring-darwin.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/othellog.umd.cjs",
  "module": "./dist/othellog.js",
  "types": "./dist/othellog.d.ts",
  "exports": {
    ".": {
      "import": "./dist/othellog.js",
      "require": "./dist/othellog.umd.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepublish": "pnpm run build",
    "lint:oxlint": "oxlint . --fix --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix --cache",
    "lint": "pnpm run lint:oxlint && pnpm run lint:eslint",
    "sizecheck": "npx vite-bundle-visualizer",
    "taze": "npx taze"
  },
  "dependencies": {
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/api-logs": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@microsoft/api-extractor": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-flat-config-utils": "catalog:",
    "eslint-plugin-format": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "eslint-plugin-pnpm": "catalog:",
    "eslint-plugin-unicorn": "catalog:",
    "oxlint": "catalog:",
    "taze": "catalog:",
    "typescript": "catalog:",
    "unplugin-auto-import": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vite-bundle-visualizer": "catalog:"
  },
  "engines": {
    "node": ">=24.14",
    "pnpm": ">=10"
  }
}
