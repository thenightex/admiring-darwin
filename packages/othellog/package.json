{
  "name": "@thenightex/othellog",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "author": {
    "name": "Sascha Hanke",
    "email": "s.hanke1316@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thenightex/admiring-darwin.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/othellog.umd.cjs",
  "module": "./dist/othellog.js",
  "types": "types.d.ts",
  "exports": {
    ".": {
      "import": "./dist/othellog.js",
      "require": "./dist/othellog.umd.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepublish": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sizecheck": "npx vite-bundle-visualizer"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.9",
    "vite-bundle-visualizer": "^1.2.1"
  },
  "engines": {
    "node": ">=24.14",
    "pnpm": ">=10"
  }
}
